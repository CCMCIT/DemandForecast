<mxfile host="app.diagrams.net">
  <diagram id="recursive-forecast-flow" name="Daily Inventory Forecast (plain language)">
    <mxGraphModel dx="900" dy="900" grid="1" gridSize="10" guides="1" tooltips="1"
                  connect="1" arrows="1" fold="1" page="1" pageScale="1"
                  pageWidth="950" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="How we forecast daily chassis inventory"
                style="text;html=1;align=center;fontSize=20;fontStyle=1;fontColor=#1A2B3C;"
                vertex="1" parent="1"><mxGeometry x="255" y="20" width="440" height="30" as="geometry"/></mxCell>
        <mxCell id="subtitle" value="Each day&#39;s forecast becomes the starting point for the next day."
                style="text;html=1;align=center;fontSize=13;fontColor=#5A6B7C;"
                vertex="1" parent="1"><mxGeometry x="255" y="52" width="440" height="20" as="geometry"/></mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="How to read this diagram&#10;&#10;• Green = start / finish&#10;• Blue = the model doing the math&#10;• Yellow diamond = a yes / no choice&#10;• Orange = saving the result&#10;&#10;We work out ALL the days first, then save the whole forecast in one step."
                style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=left;spacingLeft=8;spacingTop=4;verticalAlign=top;size=16;"
                vertex="1" parent="1"><mxGeometry x="660" y="190" width="250" height="190" as="geometry"/></mxCell>

        <!-- Flow nodes -->
        <mxCell id="start" value="Start"
                style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=1;"
                vertex="1" parent="1"><mxGeometry x="390" y="100" width="160" height="50" as="geometry"/></mxCell>

        <mxCell id="seed" value="Take yesterday&#39;s known ending inventory&#10;as our starting number"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=13;"
                vertex="1" parent="1"><mxGeometry x="340" y="185" width="260" height="55" as="geometry"/></mxCell>

        <mxCell id="setstart" value="Set the STARTING inventory for this day"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=13;"
                vertex="1" parent="1"><mxGeometry x="340" y="285" width="260" height="60" as="geometry"/></mxCell>

        <mxCell id="addinfo" value="Add the other things we expect that day&#10;(for example, vessel arrivals)"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=13;"
                vertex="1" parent="1"><mxGeometry x="340" y="385" width="260" height="60" as="geometry"/></mxCell>

        <mxCell id="model" value="The model works out this day&#39;s&#10;ENDING inventory&#10;(plus a likely lowest-to-highest range)"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;fontStyle=1;"
                vertex="1" parent="1"><mxGeometry x="330" y="485" width="280" height="70" as="geometry"/></mxCell>

        <mxCell id="carry" value="Use this day&#39;s predicted ending&#10;as the NEXT day&#39;s starting inventory"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=13;"
                vertex="1" parent="1"><mxGeometry x="340" y="595" width="260" height="60" as="geometry"/></mxCell>

        <mxCell id="decision" value="Any more days&#10;to forecast?"
                style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;"
                vertex="1" parent="1"><mxGeometry x="370" y="695" width="200" height="110" as="geometry"/></mxCell>

        <mxCell id="save" value="Save the whole forecast&#10;to the database&#10;(all days, with their ranges)"
                style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=13;"
                vertex="1" parent="1"><mxGeometry x="375" y="855" width="190" height="90" as="geometry"/></mxCell>

        <mxCell id="end" value="Done&#10;Ready for the dashboard"
                style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;fontStyle=1;"
                vertex="1" parent="1"><mxGeometry x="385" y="985" width="170" height="55" as="geometry"/></mxCell>

        <!-- Side notes -->
        <mxCell id="noteStart" value="Day 1 uses yesterday&#39;s REAL ending inventory.&#10;Later days use the previous day&#39;s FORECAST&#10;(we flag those as forecast-based)."
                style="shape=note;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=12;align=left;spacingLeft=8;spacingTop=4;verticalAlign=middle;size=14;"
                vertex="1" parent="1"><mxGeometry x="30" y="278" width="280" height="80" as="geometry"/></mxCell>

        <mxCell id="noteLoop" value="This &#39;chaining&#39; is the key idea:&#10;each day builds on the day before,&#10;so we work through them one at a time."
                style="shape=note;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=12;align=left;spacingLeft=8;spacingTop=4;verticalAlign=middle;size=14;"
                vertex="1" parent="1"><mxGeometry x="30" y="705" width="280" height="90" as="geometry"/></mxCell>

        <!-- Edges -->
        <mxCell id="e_start" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#6C8EBF;"
                edge="1" parent="1" source="start" target="seed"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_seed" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#6C8EBF;"
                edge="1" parent="1" source="seed" target="setstart"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_set" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#6C8EBF;"
                edge="1" parent="1" source="setstart" target="addinfo"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_add" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#6C8EBF;"
                edge="1" parent="1" source="addinfo" target="model"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_model" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#6C8EBF;"
                edge="1" parent="1" source="model" target="carry"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_carry" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#6C8EBF;"
                edge="1" parent="1" source="carry" target="decision"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Loop back: Yes -->
        <mxCell id="e_yes" value="Yes:&#10;go to the next day"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#D79B00;strokeWidth=2;fontColor=#B8860B;fontSize=12;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
                edge="1" parent="1" source="decision" target="setstart"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- No -> save -->
        <mxCell id="e_no" value="No:&#10;all days done"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#82B366;strokeWidth=2;fontColor=#4C7A2E;fontSize=12;exitX=0.5;exitY=1;exitDx=0;exitDy=0;"
                edge="1" parent="1" source="decision" target="save"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_save" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#82B366;"
                edge="1" parent="1" source="save" target="end"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Note connectors (dashed, no arrows) -->
        <mxCell id="e_noteStart" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;"
                edge="1" parent="1" source="noteStart" target="setstart"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_noteLoop" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;"
                edge="1" parent="1" source="noteLoop" target="decision"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
